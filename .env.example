# ── Copy this to .env and fill in your real values ──────────
# Never commit .env to git — keep these secret!

# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# From twilio.com → Account Info dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number you bought for this salon (E.164 format)
TWILIO_SALON_PHONE=+14175550123

# Railway sets PORT automatically — leave this for local dev
PORT=3000
